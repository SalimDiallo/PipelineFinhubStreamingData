# Copier ce fichier en `.env` et renseigner les valeurs.

# Clé API Finnhub (https://finnhub.io/dashboard)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Symboles à suivre (séparés par des virgules)
SYMBOLS=AAPL,MSFT,AMZN

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TOPIC_TRADES=stock.trades
TOPIC_QUOTES=stock.quotes
TOPIC_CANDLES=stock.candles

# Copier ce fichier en `.env` et renseigner les valeurs.

# Clé API Finnhub (https://finnhub.io/dashboard)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Symboles à suivre (séparés par des virgules)
SYMBOLS=AAPL,MSFT,AMZN

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
TOPIC_TRADES=stock.trades
TOPIC_QUOTES=stock.quotes
TOPIC_CANDLES=stock.candles

# Data lake S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=datalake
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Consumer
CONSUMER_GROUP=finhub-consumers
BATCH_SIZE=100
BATCH_TIMEOUT_S=10
